        set(CMAKE_SYSTEM_PROCESSOR "ARM64")
    elseif (CMAKE_C_COMPILER_ARCHITECTURE_ID STREQUAL "x64")
        set(CMAKE_SYSTEM_PROCESSOR "AMD64")
